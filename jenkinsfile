pipeline {
    agent {
        node { 
            label 'ROBOSHOP'
        }
    }
    environment {
        COURSE = "Jenkins"
        TRAINERNAME = "SivaKumar"
    }
    options {
        disableConcurrentBuilds()
        timeout (time: 3, unit: "MINUTES")
    }
    parameters {
        string(name: 'JenkinsPmName', defaultValue: 'Mr Jenkins', description: 'Who should I say hello to?')
        text(name: 'BIOGRAPHY', defaultValue: 'Text Message from Jenkins Parameters', description: 'Enter some information about the person')
        booleanParam(name: 'DEPLOY', defaultValue: false, description: 'Toggle this value')
        choice(name: 'CHOICE', choices: ['One', 'Two', 'Three'], description: 'Pick something')
        password(name: 'PASSWORD', defaultValue: 'SECRET', description: 'Enter a password')
    }
    stages {
        stage ('Github-webhook-check') {
            echo "GitHub webhook initiated automatically"
        }
        stage ('Build') {
            steps {
                script {
                    sh """
                        echo "This is Build Block from Roboshop agent node"
                        sleep 10
                        echo "Environment Variables loading; course: ${COURSE} & trainer: ${TRAINERNAME} "

                    """
                }
            }
        }
        stage ('Test') {
            steps {
                script {
                    sh """
                        echo "Testing Parameters block inputs"
                        sleep 5
                        echo "Name: ${params.JenkinsPmName}"
                        echo "Text: ${params.BIOGRAPHY}"
                        echo "Choice: ${params.CHOICE}"
                        echo "Password: ${params.PASSWORD}"

                    """
                }
            }
        }
        stage ('Deploy') {
            when {
                expression { 
                    "${params.DEPLOY}" == "true"
                }
            }
            steps {
                script {
                    sh """
                        echo "Final Stage Deployment by giving the true from parameter using when condition"

                    """
                }
            }
        }
    }
    post {
        always {
            echo "post build checks as final"
        }
        success {
            echo "pipeline success"
        }
        failure {
            echo "pipeline failure"
        }
    }
}